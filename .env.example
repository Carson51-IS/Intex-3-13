# Copy this file to ".env" in THIS folder (Intex repo root). Never commit .env.
# Local/API on your machine: loaded automatically on startup (Program.cs + DotNetEnv).
# Azure App Service: this file is NOT loaded — set the same names under Configuration → Application settings.

# --- Supabase PostgreSQL (Settings → Database → Connection string, or build manually) ---
# Use the database password you created for the project (not the anon API key).
# Direct host (db.PROJECT_REF.supabase.co) can fail DNS on some networks; if so use the pooler from Connect:
# Session pooler: host *.pooler.supabase.com, port 5432, user often postgres.<ref>
# Transaction pooler: port 6543, user postgres.<ref> — Program.cs sets MaxAutoPrepare=0 for port 6543.
# Example (password = your DB password from Supabase, not the anon key):
# ConnectionStrings__DefaultConnection=Host=aws-1-us-east-1.pooler.supabase.com;Port=6543;Database=postgres;Username=postgres.YOUR_PROJECT_REF;Password=YOUR_DB_PASSWORD;SSL Mode=Require;Trust Server Certificate=true
ConnectionStrings__DefaultConnection=Host=db.YOUR_PROJECT_REF.supabase.co;Port=5432;Database=postgres;Username=postgres;Password=YOUR_DB_PASSWORD;SSL Mode=Require;Trust Server Certificate=true

# --- JWT (required; min ~32 chars for HS256) ---
Jwt__Key=REPLACE_WITH_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARACTERS_LONG
Jwt__Issuer=HavenLightApi
Jwt__Audience=HavenLightApp
Jwt__ExpirationMinutes=60

# --- Google OAuth (.NET maps __ → : ; must match Program.cs: Authentication:Google:...) ---
# Google Cloud Console → Credentials → OAuth 2.0 Client ID (Web application).
# Authorized redirect URI: https://YOUR-API-HOST/signin-google  (local: http://localhost:5055/signin-google)
# Both values are required or the API omits Google from /api/auth/providers (login page hides the button).
Authentication__Google__ClientId=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
Authentication__Google__ClientSecret=YOUR_GOOGLE_CLIENT_SECRET
