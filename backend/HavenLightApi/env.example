# ASP.NET Core reads environment variables; use __ for nested keys (e.g. Jwt__Key).
# Copy values into User Secrets, Azure App Service Configuration, or your shell — do not commit real secrets.
#
# For local PowerShell (session only):
#   $env:ConnectionStrings__DefaultConnection = "Host=...;..."
#
# For User Secrets (recommended local dev):
#   cd backend/HavenLightApi
#   dotnet user-secrets init
#   dotnet user-secrets set "ConnectionStrings:DefaultConnection" "Host=...;..."

# --- Supabase Postgres (Project Settings → Database) ---
# Use "Connection string" → URI, or build Npgsql string manually.
# Host is often: db.YOUR_PROJECT_REF.supabase.co  (check the dashboard)
# Password: the database password you set when creating the project (not the anon key).
ConnectionStrings__DefaultConnection=Host=db.YOUR_PROJECT_REF.supabase.co;Port=5432;Database=postgres;Username=postgres;Password=YOUR_DATABASE_PASSWORD;SSL Mode=Require;Trust Server Certificate=true

# --- JWT (signing tokens for /api/auth) ---
Jwt__Key=CHANGE-TO-A-LONG-RANDOM-SECRET-AT-LEAST-32-CHARACTERS
Jwt__Issuer=HavenLightApi
Jwt__Audience=HavenLightApp
Jwt__ExpirationMinutes=60

# --- CORS (comma-separated origins; required for Vercel / production frontend) ---
# Cors__AllowedOrigins=https://your-project.vercel.app
