# Copy this file to ".env.local" in this folder (same directory as package.json).
# Never commit .env.local — it is gitignored.

# --- Supabase (Project Settings → API) ---
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- Your .NET API ---
# Include "/api" — routes are under /api. Local dev example below.
# On Vercel (Production): set to your Azure URL, e.g.
#   https://havenlight-api-intex3-13.azurewebsites.net/api
# Redeploy after changing env vars (Vite bakes them in at build time).
# Leave unset in local dev to use Vite proxy → http://localhost:5055 (run API with `dotnet run`).
# Or set explicitly, e.g. VITE_API_URL=http://localhost:5055/api
VITE_API_URL=
