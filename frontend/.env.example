# Copy this file to ".env.local" in this folder (same directory as package.json).
# Never commit .env.local — it is gitignored.

# --- Supabase (Project Settings → API) ---
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- Your .NET API (path must include /api) ---
# Local: leave unset to use Vite dev server proxy → http://localhost:5055 (see vite.config.ts).
# Production (Vercel): required, e.g. https://your-api.azurewebsites.net/api — redeploy after changes.
# VITE_API_URL=

# --- Google OAuth (same Client ID as backend; must be a "Web application" type) ---
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
